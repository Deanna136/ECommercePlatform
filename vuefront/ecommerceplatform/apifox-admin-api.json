{
  "openapi": "3.0.3",
  "info": {
    "title": "综合型电商平台 - 管理员端接口",
    "version": "v1.0",
    "description": "综合型电商平台管理员端 REST API 接口文档\n\n## 认证方式\n除登录接口外，所有接口需在 Header 中携带 `admin_token`\n\n## 测试账号\n- 用户名: admin\n- 密码: 123456\n\n## 环境\n- 开发环境: http://localhost:8080"
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "本地开发环境" }
  ],
  "security": [
    { "AdminAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "AdminAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "admin_token",
        "description": "管理员JWT Token，登录后获取，有效期2小时"
      }
    },
    "schemas": {
      "Result": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "description": "状态码，200为成功", "example": 200 },
          "msg": { "type": "string", "description": "提示信息", "example": "操作成功" },
          "data": { "description": "响应数据，无数据时为null" }
        }
      },
      "LoginDTO": {
        "type": "object",
        "required": ["userName", "password"],
        "properties": {
          "userName": { "type": "string", "description": "用户名", "example": "admin" },
          "password": { "type": "string", "description": "密码", "example": "123456" }
        }
      },
      "UpdatePasswordDTO": {
        "type": "object",
        "required": ["id", "password"],
        "properties": {
          "id": { "type": "integer", "description": "管理员ID", "example": 1 },
          "password": { "type": "string", "description": "新密码，长度≥6位", "example": "newpass123" }
        }
      },
      "AdminHandleDTO": {
        "type": "object",
        "properties": {
          "remark": { "type": "string", "description": "备注" },
          "reason": { "type": "string", "description": "原因" },
          "rejectReason": { "type": "string", "description": "拒绝原因" },
          "handleResult": { "type": "string", "description": "处理结果: refunded/completed/cancelled", "enum": ["refunded", "completed", "cancelled"] }
        }
      },
      "AdministratorLoginVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "管理员ID" },
          "userName": { "type": "string", "description": "用户名" },
          "token": { "type": "string", "description": "JWT Token" }
        }
      },
      "BuyerVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "userName": { "type": "string" },
          "name": { "type": "string" },
          "idNumber": { "type": "string" },
          "sex": { "type": "string", "enum": ["male", "female"] },
          "phone": { "type": "string" },
          "address": { "type": "string" },
          "image": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "locked", "deleted"] },
          "createTime": { "type": "string", "format": "date-time" },
          "updateTime": { "type": "string", "format": "date-time" }
        }
      },
      "SellerVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "userName": { "type": "string" },
          "name": { "type": "string" },
          "idNumber": { "type": "string" },
          "sex": { "type": "string", "enum": ["male", "female"] },
          "phone": { "type": "string" },
          "address": { "type": "string" },
          "image": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "locked", "deleted"] },
          "storeName": { "type": "string" },
          "storeCategory": { "type": "string", "enum": ["clothing", "food", "electronics", "home_living", "mother_baby", "sports", "books", "others"] },
          "createTime": { "type": "string", "format": "date-time" },
          "updateTime": { "type": "string", "format": "date-time" }
        }
      },
      "ProductVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "productNo": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string", "enum": ["clothing", "food", "electronics", "home_living", "mother_baby", "sports", "books", "others"] },
          "sku": { "type": "integer" },
          "price": { "type": "number", "format": "double" },
          "image": { "type": "string" },
          "description": { "type": "string" },
          "sellerId": { "type": "integer" },
          "sellerName": { "type": "string" },
          "storeName": { "type": "string" },
          "status": { "type": "string", "enum": ["offsale", "pending_review", "approved", "onsale", "rejected", "out_of_stock", "suspend", "deleted"] },
          "salesCount": { "type": "integer" },
          "createTime": { "type": "string", "format": "date-time" },
          "updateTime": { "type": "string", "format": "date-time" }
        }
      },
      "OrderVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "orderNo": { "type": "string" },
          "buyerId": { "type": "integer" },
          "buyerName": { "type": "string" },
          "sellerId": { "type": "integer" },
          "sellerName": { "type": "string" },
          "amount": { "type": "number", "format": "double" },
          "status": { "type": "string", "enum": ["pending", "paid", "processing", "shipped", "delivered", "completed", "cancelled", "refunded", "failed", "abnormal"] },
          "createTime": { "type": "string", "format": "date-time" },
          "updateTime": { "type": "string", "format": "date-time" }
        }
      },
      "OrderDetailVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "orderNo": { "type": "string" },
          "buyerId": { "type": "integer" },
          "buyerName": { "type": "string" },
          "sellerId": { "type": "integer" },
          "sellerName": { "type": "string" },
          "amount": { "type": "number", "format": "double" },
          "status": { "type": "string" },
          "createTime": { "type": "string", "format": "date-time" },
          "updateTime": { "type": "string", "format": "date-time" },
          "orderItems": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrderItemVO" }
          }
        }
      },
      "OrderItemVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "productId": { "type": "integer" },
          "productName": { "type": "string" },
          "productNo": { "type": "string" },
          "quantity": { "type": "integer" },
          "unitPrice": { "type": "number", "format": "double" },
          "totalPrice": { "type": "number", "format": "double" }
        }
      }
    }
  },
  "tags": [
    { "name": "认证模块", "description": "管理员登录与密码管理" },
    { "name": "买家管理", "description": "管理员对买家账号的查询与管控" },
    { "name": "卖家管理", "description": "管理员对卖家账号的查询与管控" },
    { "name": "商品管理", "description": "管理员对商品的审核与管控" },
    { "name": "订单管理", "description": "管理员对订单的监督与处理" },
    { "name": "文件管理", "description": "腾讯云COS文件上传/下载/删除" }
  ],
  "paths": {
    "/admin/login": {
      "post": {
        "tags": ["认证模块"],
        "summary": "管理员登录",
        "description": "使用用户名密码登录，成功返回JWT Token。Token存入Redis白名单，有效期2小时；重复登录会覆盖旧Token。",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginDTO" },
              "example": { "userName": "admin", "password": "123456" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "code": { "example": 200 }, "msg": { "example": "操作成功" }, "data": { "$ref": "#/components/schemas/AdministratorLoginVO" } } }
              }
            }
          },
          "1001": { "description": "用户不存在" },
          "1002": { "description": "密码错误" }
        }
      }
    },
    "/admin/updatePwd": {
      "post": {
        "tags": ["认证模块"],
        "summary": "管理员修改密码",
        "security": [{ "AdminAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdatePasswordDTO" }
            }
          }
        },
        "responses": {
          "200": { "description": "修改成功" },
          "1001": { "description": "用户不存在" },
          "1006": { "description": "密码长度不足6位" }
        }
      }
    },
    "/admin/logout": {
      "get": {
        "tags": ["认证模块"],
        "summary": "管理员退出",
        "description": "从Redis删除Token，使其立即失效。",
        "security": [{ "AdminAuth": [] }],
        "responses": {
          "200": { "description": "退出成功" }
        }
      }
    },
    "/admin/buyer/list": {
      "get": {
        "tags": ["买家管理"],
        "summary": "查看买家列表",
        "description": "获取所有买家列表，不含密码字段。",
        "responses": {
          "200": { "description": "买家列表", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/BuyerVO" } } } } },
          "401": { "description": "未登录或Token失效" }
        }
      }
    },
    "/admin/buyer/{id}": {
      "get": {
        "tags": ["买家管理"],
        "summary": "查看买家详情",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "买家ID" }
        ],
        "responses": {
          "200": { "description": "买家详情", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BuyerVO" } } } },
          "1101": { "description": "买家不存在" }
        }
      }
    },
    "/admin/buyer/query": {
      "get": {
        "tags": ["买家管理"],
        "summary": "买家条件筛选",
        "description": "多条件筛选买家，AND关系。所有参数可选，无匹配返回空数组。",
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "integer" }, "description": "买家ID(精确)" },
          { "name": "userName", "in": "query", "schema": { "type": "string" }, "description": "用户名(模糊)" },
          { "name": "name", "in": "query", "schema": { "type": "string" }, "description": "真实姓名(模糊)" },
          { "name": "idNumber", "in": "query", "schema": { "type": "string" }, "description": "身份证号(精确)" },
          { "name": "phone", "in": "query", "schema": { "type": "string" }, "description": "手机号(精确)" },
          { "name": "sex", "in": "query", "schema": { "type": "string", "enum": ["male", "female"] }, "description": "性别" },
          { "name": "address", "in": "query", "schema": { "type": "string" }, "description": "地址(模糊)" },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "locked", "deleted"] }, "description": "账号状态" }
        ],
        "responses": {
          "200": { "description": "筛选结果" }
        }
      }
    },
    "/admin/buyer/{id}/ban": {
      "put": {
        "tags": ["买家管理"],
        "summary": "封禁买家账号",
        "description": "将买家状态改为locked。已封禁账号不可重复封禁。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "买家ID" }
        ],
        "responses": {
          "200": { "description": "封禁成功" },
          "1101": { "description": "买家不存在" },
          "1004": { "description": "账号已被封禁" }
        }
      }
    },
    "/admin/buyer/{id}/unban": {
      "put": {
        "tags": ["买家管理"],
        "summary": "解封买家账号",
        "description": "将买家状态从locked改为active。仅locked状态可解封。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "买家ID" }
        ],
        "responses": {
          "200": { "description": "解封成功" },
          "1101": { "description": "买家不存在" },
          "4003": { "description": "状态不允许操作" }
        }
      }
    },
    "/admin/seller/list": {
      "get": {
        "tags": ["卖家管理"],
        "summary": "查看卖家列表",
        "description": "获取所有卖家列表（含店铺信息），不含密码字段。",
        "responses": {
          "200": { "description": "卖家列表", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/SellerVO" } } } } },
          "401": { "description": "未登录或Token失效" }
        }
      }
    },
    "/admin/seller/{id}": {
      "get": {
        "tags": ["卖家管理"],
        "summary": "查看卖家详情",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "卖家ID" }
        ],
        "responses": {
          "200": { "description": "卖家详情", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SellerVO" } } } },
          "1201": { "description": "卖家不存在" }
        }
      }
    },
    "/admin/seller/query": {
      "get": {
        "tags": ["卖家管理"],
        "summary": "卖家条件筛选",
        "description": "多条件筛选卖家，AND关系。所有参数可选。",
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "integer" }, "description": "卖家ID(精确)" },
          { "name": "userName", "in": "query", "schema": { "type": "string" }, "description": "用户名(模糊)" },
          { "name": "name", "in": "query", "schema": { "type": "string" }, "description": "真实姓名(模糊)" },
          { "name": "idNumber", "in": "query", "schema": { "type": "string" }, "description": "身份证号(精确)" },
          { "name": "phone", "in": "query", "schema": { "type": "string" }, "description": "手机号(精确)" },
          { "name": "sex", "in": "query", "schema": { "type": "string", "enum": ["male", "female"] }, "description": "性别" },
          { "name": "address", "in": "query", "schema": { "type": "string" }, "description": "地址(模糊)" },
          { "name": "storeName", "in": "query", "schema": { "type": "string" }, "description": "店铺名称(模糊)" },
          { "name": "storeCategory", "in": "query", "schema": { "type": "string", "enum": ["clothing", "food", "electronics", "home_living", "mother_baby", "sports", "books", "others"] }, "description": "店铺类型" },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "locked", "deleted"] }, "description": "账号状态" }
        ],
        "responses": {
          "200": { "description": "筛选结果" }
        }
      }
    },
    "/admin/seller/{id}/ban": {
      "put": {
        "tags": ["卖家管理"],
        "summary": "封禁卖家账号",
        "description": "将卖家状态改为locked。卖家被封禁后其名下商品自动suspend。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "卖家ID" }
        ],
        "responses": {
          "200": { "description": "封禁成功" },
          "1201": { "description": "卖家不存在" }
        }
      }
    },
    "/admin/seller/{id}/unban": {
      "put": {
        "tags": ["卖家管理"],
        "summary": "解封卖家账号",
        "description": "将卖家状态从locked改为active。解封不自动恢复商品状态。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "卖家ID" }
        ],
        "responses": {
          "200": { "description": "解封成功" },
          "1201": { "description": "卖家不存在" },
          "4003": { "description": "状态不允许操作" }
        }
      }
    },
    "/admin/product/list": {
      "get": {
        "tags": ["商品管理"],
        "summary": "查看商品列表",
        "description": "获取所有商品列表（不含deleted状态商品）。",
        "responses": {
          "200": { "description": "商品列表", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ProductVO" } } } } }
        }
      }
    },
    "/admin/product/{id}": {
      "get": {
        "tags": ["商品管理"],
        "summary": "查看商品详情",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "商品ID" }
        ],
        "responses": {
          "200": { "description": "商品详情", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProductVO" } } } },
          "4001": { "description": "商品不存在" }
        }
      }
    },
    "/admin/product/query": {
      "get": {
        "tags": ["商品管理"],
        "summary": "商品条件筛选",
        "description": "多条件筛选商品，AND关系。常用: status=pending_review 查待审核商品。",
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "integer" }, "description": "商品ID(精确)" },
          { "name": "productNo", "in": "query", "schema": { "type": "string" }, "description": "商品编号(精确)" },
          { "name": "name", "in": "query", "schema": { "type": "string" }, "description": "商品名称(模糊)" },
          { "name": "category", "in": "query", "schema": { "type": "string" }, "description": "商品类型" },
          { "name": "sellerId", "in": "query", "schema": { "type": "integer" }, "description": "卖家ID" },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["offsale", "pending_review", "approved", "onsale", "rejected", "out_of_stock", "suspend", "deleted"] }, "description": "商品状态" },
          { "name": "minPrice", "in": "query", "schema": { "type": "number" }, "description": "最低价格" },
          { "name": "maxPrice", "in": "query", "schema": { "type": "number" }, "description": "最高价格" }
        ],
        "responses": {
          "200": { "description": "筛选结果" }
        }
      }
    },
    "/admin/product/{id}/approve": {
      "put": {
        "tags": ["商品管理"],
        "summary": "审核通过（上架）",
        "description": "审核通过商品上架，pending_review → onsale。仅待审核状态可操作。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "商品ID" }
        ],
        "responses": {
          "200": { "description": "审核通过" },
          "4001": { "description": "商品不存在" },
          "4003": { "description": "状态不允许操作" }
        }
      }
    },
    "/admin/product/{id}/reject": {
      "put": {
        "tags": ["商品管理"],
        "summary": "审核拒绝",
        "description": "审核拒绝商品上架，pending_review → rejected。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "商品ID" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "rejectReason": { "type": "string", "description": "拒绝原因" } } },
              "example": { "rejectReason": "商品描述不符合平台规范" }
            }
          }
        },
        "responses": {
          "200": { "description": "审核拒绝" },
          "4003": { "description": "状态不允许操作" }
        }
      }
    },
    "/admin/product/{id}/suspend": {
      "put": {
        "tags": ["商品管理"],
        "summary": "强制下架商品",
        "description": "强制下架商品，状态变为suspend。除deleted外任何状态均可操作。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "商品ID" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "reason": { "type": "string", "description": "下架原因" } } },
              "example": { "reason": "商品涉嫌违规" }
            }
          }
        },
        "responses": {
          "200": { "description": "下架成功" },
          "4001": { "description": "商品不存在" }
        }
      }
    },
    "/admin/order/list": {
      "get": {
        "tags": ["订单管理"],
        "summary": "查看订单列表",
        "description": "获取全平台所有订单列表（不含订单明细）。",
        "responses": {
          "200": { "description": "订单列表", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OrderVO" } } } } }
        }
      }
    },
    "/admin/order/{id}": {
      "get": {
        "tags": ["订单管理"],
        "summary": "查看订单详情",
        "description": "查看订单详情（含orderItems商品明细和价格快照）。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "订单ID" }
        ],
        "responses": {
          "200": { "description": "订单详情", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OrderDetailVO" } } } },
          "6001": { "description": "订单不存在" }
        }
      }
    },
    "/admin/order/query": {
      "get": {
        "tags": ["订单管理"],
        "summary": "订单条件筛选",
        "description": "多条件筛选订单，AND关系。常用: status=abnormal 查异常订单。",
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "integer" }, "description": "订单ID(精确)" },
          { "name": "orderNo", "in": "query", "schema": { "type": "string" }, "description": "订单编号(精确)" },
          { "name": "buyerId", "in": "query", "schema": { "type": "integer" }, "description": "买家ID" },
          { "name": "sellerId", "in": "query", "schema": { "type": "integer" }, "description": "卖家ID" },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["pending", "paid", "processing", "shipped", "delivered", "completed", "cancelled", "refunded", "failed", "abnormal"] }, "description": "订单状态" },
          { "name": "startTime", "in": "query", "schema": { "type": "string" }, "description": "起始时间(yyyy-MM-dd)" },
          { "name": "endTime", "in": "query", "schema": { "type": "string" }, "description": "截止时间(yyyy-MM-dd)" }
        ],
        "responses": {
          "200": { "description": "筛选结果" }
        }
      }
    },
    "/admin/order/{id}/forceClose": {
      "put": {
        "tags": ["订单管理"],
        "summary": "强制关闭订单",
        "description": "强制关闭订单，状态变为cancelled。已处于终态(completed/cancelled/refunded/failed)的订单不可关闭。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "订单ID" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "remark": { "type": "string", "description": "关闭原因备注" } } },
              "example": { "remark": "涉嫌欺诈交易" }
            }
          }
        },
        "responses": {
          "200": { "description": "关闭成功" },
          "6001": { "description": "订单不存在" },
          "6003": { "description": "状态不允许操作" }
        }
      }
    },
    "/admin/order/{id}/handleAbnormal": {
      "put": {
        "tags": ["订单管理"],
        "summary": "订单异常处理",
        "description": "处理异常订单。仅abnormal状态可操作，处理结果不可撤销！handleResult必传: refunded/completed/cancelled。",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "订单ID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminHandleDTO" },
              "example": { "handleResult": "refunded", "remark": "经核实买家诉求合理，支持退款" }
            }
          }
        },
        "responses": {
          "200": { "description": "处理完成" },
          "6001": { "description": "订单不存在" },
          "6003": { "description": "状态不允许操作" },
          "400": { "description": "handleResult参数非法" }
        }
      }
    },
    "/admin/file/upload": {
      "post": {
        "tags": ["文件管理"],
        "summary": "上传图片",
        "description": "上传图片到腾讯云COS，返回图片URL。Content-Type: multipart/form-data",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary", "description": "图片文件" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "上传成功，返回URL" }
        }
      }
    },
    "/admin/file/download": {
      "get": {
        "tags": ["文件管理"],
        "summary": "下载图片",
        "description": "通过COS URL下载图片，返回二进制数据。",
        "parameters": [
          { "name": "url", "in": "query", "required": true, "schema": { "type": "string" }, "description": "图片完整URL" }
        ],
        "responses": {
          "200": { "description": "图片二进制数据" }
        }
      }
    },
    "/admin/file/delete": {
      "post": {
        "tags": ["文件管理"],
        "summary": "删除图片",
        "description": "从腾讯云COS删除图片。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "url": { "type": "string", "description": "图片URL" } } }
            }
          }
        },
        "responses": {
          "200": { "description": "删除成功" }
        }
      }
    }
  }
}
