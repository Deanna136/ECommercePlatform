{
  "info": {
    "name": "综合型电商平台 - 管理员端 API",
    "description": "管理员端所有接口，包括认证、文件上传、买家/卖家/商品/订单管理。\n\n## 使用说明\n1. 先调用「管理员登录」，Test 脚本会自动把 token 存入 Collection 变量 {{token}}\n2. 其他接口已配置 admin_token: {{token}} 请求头，无需手动填写\n3. 同一账号重复登录会使旧 token 失效（SSO），所以不要多次登录",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "admin_token",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{token}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "认证模块",
      "item": [
        {
          "name": "管理员登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.code === 200 && json.data && json.data.token) {",
                  "        pm.collectionVariables.set('token', json.data.token);",
                  "        console.log('Token 已自动存入 Collection 变量');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/login",
              "host": ["{{base_url}}"],
              "path": ["admin", "login"]
            },
            "description": "管理员登录，成功后 token 自动存入 Collection 变量 {{token}}"
          },
          "response": [
            {
              "name": "成功",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n  \"code\": 200,\n  \"msg\": \"操作成功\",\n  \"data\": {\n    \"id\": 1,\n    \"userName\": \"admin\",\n    \"token\": \"eyJhbGciOiJIUzI1NiJ9...\"\n  }\n}"
            }
          ]
        },
        {
          "name": "管理员退出",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/logout",
              "host": ["{{base_url}}"],
              "path": ["admin", "logout"]
            }
          },
          "response": [
            {
              "name": "成功",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"code\": 200,\n  \"msg\": \"操作成功\",\n  \"data\": \"退出成功\"\n}"
            }
          ]
        },
        {
          "name": "管理员修改密码",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"password\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/updatePwd",
              "host": ["{{base_url}}"],
              "path": ["admin", "updatePwd"]
            }
          },
          "response": [
            {
              "name": "成功",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"code\": 200,\n  \"msg\": \"操作成功\",\n  \"data\": \"密码修改成功！\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "买家管理",
      "item": [
        {
          "name": "查看买家列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/buyer/list",
              "host": ["{{base_url}}"],
              "path": ["admin", "buyer", "list"]
            }
          }
        },
        {
          "name": "查看买家详情",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/buyer/{{buyerId}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "buyer", "{{buyerId}}"]
            },
            "description": "替换 buyerId 为目标买家 ID"
          }
        },
        {
          "name": "买家条件筛选",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/buyer/query?status=active",
              "host": ["{{base_url}}"],
              "path": ["admin", "buyer", "query"],
              "query": [
                { "key": "id", "value": "", "disabled": true },
                { "key": "userName", "value": "", "disabled": true },
                { "key": "name", "value": "", "disabled": true },
                { "key": "idNumber", "value": "", "disabled": true },
                { "key": "phone", "value": "", "disabled": true },
                { "key": "sex", "value": "", "disabled": true },
                { "key": "address", "value": "", "disabled": true },
                { "key": "status", "value": "active" }
              ]
            }
          }
        },
        {
          "name": "封禁买家",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/admin/buyer/{{buyerId}}/ban",
              "host": ["{{base_url}}"],
              "path": ["admin", "buyer", "{{buyerId}}", "ban"]
            }
          }
        },
        {
          "name": "解封买家",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/admin/buyer/{{buyerId}}/unban",
              "host": ["{{base_url}}"],
              "path": ["admin", "buyer", "{{buyerId}}", "unban"]
            }
          }
        }
      ]
    },
    {
      "name": "卖家管理",
      "item": [
        {
          "name": "查看卖家列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/seller/list",
              "host": ["{{base_url}}"],
              "path": ["admin", "seller", "list"]
            }
          }
        },
        {
          "name": "查看卖家详情",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/seller/{{sellerId}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "seller", "{{sellerId}}"]
            }
          }
        },
        {
          "name": "卖家条件筛选",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/seller/query",
              "host": ["{{base_url}}"],
              "path": ["admin", "seller", "query"],
              "query": [
                { "key": "id", "value": "", "disabled": true },
                { "key": "userName", "value": "", "disabled": true },
                { "key": "name", "value": "", "disabled": true },
                { "key": "idNumber", "value": "", "disabled": true },
                { "key": "phone", "value": "", "disabled": true },
                { "key": "sex", "value": "", "disabled": true },
                { "key": "address", "value": "", "disabled": true },
                { "key": "storeName", "value": "", "disabled": true },
                { "key": "storeCategory", "value": "", "disabled": true },
                { "key": "status", "value": "" }
              ]
            }
          }
        },
        {
          "name": "封禁卖家",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/admin/seller/{{sellerId}}/ban",
              "host": ["{{base_url}}"],
              "path": ["admin", "seller", "{{sellerId}}", "ban"]
            }
          }
        },
        {
          "name": "解封卖家",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/admin/seller/{{sellerId}}/unban",
              "host": ["{{base_url}}"],
              "path": ["admin", "seller", "{{sellerId}}", "unban"]
            }
          }
        }
      ]
    },
    {
      "name": "商品管理",
      "item": [
        {
          "name": "查看商品列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/product/list",
              "host": ["{{base_url}}"],
              "path": ["admin", "product", "list"]
            }
          }
        },
        {
          "name": "查看商品详情",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/product/{{productId}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "product", "{{productId}}"]
            }
          }
        },
        {
          "name": "商品条件筛选",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/product/query",
              "host": ["{{base_url}}"],
              "path": ["admin", "product", "query"],
              "query": [
                { "key": "id", "value": "", "disabled": true },
                { "key": "productNo", "value": "", "disabled": true },
                { "key": "name", "value": "", "disabled": true },
                { "key": "category", "value": "", "disabled": true },
                { "key": "sellerId", "value": "", "disabled": true },
                { "key": "status", "value": "" },
                { "key": "minPrice", "value": "", "disabled": true },
                { "key": "maxPrice", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "审核通过（商品上架）",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/admin/product/{{productId}}/approve",
              "host": ["{{base_url}}"],
              "path": ["admin", "product", "{{productId}}", "approve"]
            },
            "description": "仅 pending_review 状态的商品可操作"
          }
        },
        {
          "name": "审核拒绝",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rejectReason\": \"商品描述不符合平台规范\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/product/{{productId}}/reject",
              "host": ["{{base_url}}"],
              "path": ["admin", "product", "{{productId}}", "reject"]
            },
            "description": "仅 pending_review 状态的商品可操作。请求体可选。"
          }
        },
        {
          "name": "强制下架商品",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"商品涉嫌违规\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/product/{{productId}}/suspend",
              "host": ["{{base_url}}"],
              "path": ["admin", "product", "{{productId}}", "suspend"]
            },
            "description": "除 deleted 外的任何状态商品均可强制下架。请求体可选。"
          }
        }
      ]
    },
    {
      "name": "订单管理",
      "item": [
        {
          "name": "查看订单列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/order/list",
              "host": ["{{base_url}}"],
              "path": ["admin", "order", "list"]
            }
          }
        },
        {
          "name": "查看订单详情",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/order/{{orderId}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "order", "{{orderId}}"]
            }
          }
        },
        {
          "name": "订单条件筛选",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/order/query",
              "host": ["{{base_url}}"],
              "path": ["admin", "order", "query"],
              "query": [
                { "key": "id", "value": "", "disabled": true },
                { "key": "orderNo", "value": "", "disabled": true },
                { "key": "buyerId", "value": "", "disabled": true },
                { "key": "sellerId", "value": "", "disabled": true },
                { "key": "status", "value": "" },
                { "key": "startTime", "value": "", "disabled": true },
                { "key": "endTime", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "强制关闭订单",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remark\": \"涉嫌欺诈交易\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/order/{{orderId}}/forceClose",
              "host": ["{{base_url}}"],
              "path": ["admin", "order", "{{orderId}}", "forceClose"]
            },
            "description": "非终态（completed/cancelled/refunded/failed）订单可强制关闭。请求体可选。"
          }
        },
        {
          "name": "订单异常处理",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"handleResult\": \"refunded\",\n  \"remark\": \"经核实买家诉求合理\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/order/{{orderId}}/handleAbnormal",
              "host": ["{{base_url}}"],
              "path": ["admin", "order", "{{orderId}}", "handleAbnormal"]
            },
            "description": "仅 abnormal 状态订单可处理。handleResult 必填：refunded / completed / cancelled。"
          }
        }
      ]
    }
  ]
}
